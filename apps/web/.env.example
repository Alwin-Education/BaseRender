# Optional: point API requests at a remote backend (Phase 4+).
# Leave unset for local dev — Next.js rewrites proxy /auth, /media, /jobs, and /transcode
# to FastAPI on http://127.0.0.1:8000 (override with BASERENDER_API_PROXY_TARGET in next.config).
# NEXT_PUBLIC_API_BASE_URL=

# Optional: override the FastAPI proxy target used by next.config.ts rewrites.
# BASERENDER_API_PROXY_TARGET=http://127.0.0.1:8000

# Auth and runtime configuration live in apps/api/.env.
