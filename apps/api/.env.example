BASERENDER_AUTH_PASSWORD=change-me
BASERENDER_SESSION_SECRET=replace-with-a-long-random-string
BASERENDER_AUTH_SECURE_COOKIE=false

# Worker authentication. Use the same value in apps/worker/.env.
BASERENDER_WORKER_TOKEN=replace-with-a-long-random-worker-token

# S3 storage (job state, artifacts, source media, and render outputs).
BASERENDER_S3_BUCKET=your-bucket
BASERENDER_MEDIA_PROVIDER=s3
BASERENDER_OUTPUT_PREFIX=outputs
BASERENDER_ARTIFACT_PREFIX=baserender
BASERENDER_JOB_STATE_KEY=baserender/jobs/current.json
BASERENDER_JOB_STALE_SECONDS=3600
BASERENDER_MEDIA_URL_TTL_SECONDS=21600
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# AWS MediaConvert (hybrid render path; optional until Phase 5 API integration).
BASERENDER_MEDIACONVERT_ROLE_ARN=arn:aws:iam::123456789012:role/MediaConvertRole
BASERENDER_MEDIACONVERT_QUEUE_ARN=arn:aws:mediaconvert:us-east-1:123456789012:queues/Default
# Optional. When unset, the API discovers the account endpoint via describe_endpoints.
BASERENDER_MEDIACONVERT_ENDPOINT=

# EventBridge orchestration (Phase 5).
BASERENDER_EVENT_BUS=default
BASERENDER_EVENT_SOURCE=baserender

# Render execution backend: cloud (MediaConvert + Lambda) or worker (Render.com poll loop).
BASERENDER_RENDER_BACKEND=cloud
